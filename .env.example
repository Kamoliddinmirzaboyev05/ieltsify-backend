# ============================================
# Django Core
# ============================================
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
# Local: localhost,127.0.0.1 | Production: api.ieltsfy.uz
ALLOWED_HOSTS=localhost,127.0.0.1,api.ieltsfy.uz
FRONTEND_URL=http://localhost:3000

# ============================================
# CORS / CSRF (production: frontend deploy origins, comma-separated, no trailing slash)
# Example: https://ieltsfy.uz,https://admin.ieltsfy.uz
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=https://api.ieltsfy.uz

# ============================================
# Google Gemini API
# ============================================
GOOGLE_AI_API_KEY=
GEMINI_WRITING_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_WRITING_PRE_ANALYSIS_MODEL=gemini-2.5-flash-lite
GEMINI_SPEAKING_ASSESSMENT_MODEL=gemini-2.5-flash
GEMINI_MOCK_REPORT_MODEL=gemini-2.5-flash
GEMINI_ENABLED=true

# ============================================
# Groq Speech-to-Text
# ============================================
GROQ_API_KEY=
GROQ_STT_PRIMARY_MODEL=whisper-large-v3-turbo
GROQ_STT_FALLBACK_MODEL=whisper-large-v3
GROQ_STT_ENABLED=true

# ============================================
# Azure Speech Pronunciation Assessment
# ============================================
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_PRONUNCIATION_ENABLED=false
AZURE_SPEECH_LANGUAGE=en-US

# ============================================
# Anthropic fallback
# ============================================
ANTHROPIC_API_KEY=
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-20250514
ANTHROPIC_FALLBACK_ENABLED=false

# ============================================
# AI behavior
# ============================================
AI_PROVIDER_TIMEOUT_MS=45000
AI_MAX_RETRY_COUNT=2
AI_FALLBACK_ENABLED=true
AI_STORE_RAW_RESPONSES=false
AI_LOG_TOKEN_USAGE=true
AI_DEBUG_MODE=false

# ============================================
# Upload settings
# ============================================
WRITING_IMAGE_MAX_SIZE_MB=5
SPEAKING_AUDIO_MAX_SIZE_MB=25
SPEAKING_AUDIO_ALLOWED_TYPES=audio/webm,audio/wav,audio/mpeg,audio/mp4,audio/ogg

# ============================================
# JWT
# ============================================
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=24

# ============================================
# Google OAuth
# ============================================
GOOGLE_CLIENT_ID=

# ============================================
# Payment Gateway (test mode)
# ============================================
CLICK_SERVICE_ID=12345
CLICK_MERCHANT_ID=67890
CLICK_SECRET_KEY=
PAYME_SERVICE_ID=54321
PAYME_MERCHANT_ID=98765
PAYME_SECRET_KEY=

# ============================================
# Telegram Bot
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ============================================
# Email
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_USE_TLS=True
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
